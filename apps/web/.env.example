# Nuxt runtime config — private (server-side only, never exposed to the browser)
# Generated automatically by `make setup`. Edit as needed.

# URL of the lens API backend (no trailing slash)
NUXT_API_BASE_URL=http://localhost:8000

# Raw API key from API_KEYS_BOOTSTRAP in the root .env
NUXT_API_KEY=

# Session secret — minimum 32 characters. Generated by `make setup`.
NUXT_SESSION_PASSWORD=
