# ============================================================================
# lens - environment reference
# ----------------------------------------------------------------------------
# Copy to `.env` and edit for your local environment. This file is a broad
# reference of the full configuration surface; the canonical variables read by
# the code are the LENS_-prefixed ones documented in docs/09-configuration.md.
#
# Tiers (see docs/09-configuration.md):
#   - BOOTSTRAP: env-only, immutable at runtime (needed before DB/broker connect)
#   - DYNAMIC  : seed/default; live value overridable in the `settings` table
#                and broadcast to all instances
# ============================================================================

# ---- app role -------------------------------------------------------------
# BOOTSTRAP. One of: api / scheduler / crawler / notifier / ai / cli
APP_ROLE=api

# ---- database -------------------------------------------------------------
# BOOTSTRAP. Required.
DATABASE_URL=postgresql+asyncpg://lens:lens@localhost:5432/lens

# ---- broker ---------------------------------------------------------------
# BOOTSTRAP. Required for broker roles.
RABBITMQ_URL=amqp://lens:lens@localhost:5672/

# ---- redis (locks / throttle / idempotency / dedup) -----------------------
# BOOTSTRAP. Required for worker/scheduler.
REDIS_URL=redis://localhost:6379/0

# ---- blob storage ---------------------------------------------------------
# BOOTSTRAP. local = filesystem; s3 = S3 / MinIO.
BLOB_BACKEND=local
BLOB_BUCKET=lens
BLOB_ENDPOINT_URL=
BLOB_ACCESS_KEY=
BLOB_SECRET_KEY=
BLOB_LOCAL_PATH=./data/blobs

# ---- secrets --------------------------------------------------------------
# BOOTSTRAP. Fernet key, base64 32 bytes. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ---- api auth -------------------------------------------------------------
# BOOTSTRAP. Comma-list of initial admin api keys for first run.
# Format: "<key-id>:<raw-key>:<scopes>" ; scopes csv in {read,write,admin}.
API_KEYS_BOOTSTRAP=

# ---- logging --------------------------------------------------------------
# BOOTSTRAP for LOG_FORMAT; DYNAMIC for LOG_LEVEL.
LOG_LEVEL=INFO
LOG_FORMAT=json

# ---- crawler / scheduler / lease -----------------------------------------
GLOBAL_MIN_INTERVAL=300
MAX_SNAPSHOTS=25
CRAWLER_CONCURRENCY=8
CRAWLER_PREFETCH=16
LEASE_TTL_SECONDS=120
SCHEDULER_TICK_SECONDS=10
SCHEDULER_BATCH_SIZE=500
NOTIFY_MAX_ATTEMPTS=5
CRAWL_MAX_ATTEMPTS=4
TEMPLATE_DRIFT_COOLDOWN_HOURS=24

# ---- api rate limit -------------------------------------------------------
# DYNAMIC (hot).
RATE_LIMIT_PER_MINUTE=120

# ---- metrics --------------------------------------------------------------
METRICS_ENABLED=true

# ---- dynamic configuration (13) ------------------------------------------
# BOOTSTRAP for the backends/exchange; the catalog itself lives in code.
CONFIG_BROADCAST_BACKEND=rabbitmq
CONFIG_AUTORESTART=false
CONFIG_RECONCILE_SECONDS=60
CONFIG_EXCHANGE=config

# ---- AI tier (12, optional; AI_ENABLED=false disables everything) ---------
AI_ENABLED=false
EMBEDDING_BACKEND=local
EMBEDDING_MODEL=bge-base-en-v1.5
EMBEDDING_LONG_MODEL=bge-m3
EMBEDDING_ENDPOINT=
LLM_BACKEND=vllm
LLM_ENDPOINT=
LLM_MODEL=Qwen2.5-7B-Instruct
AI_SIGNAL_DISAGREE_DELTA=0.35
AI_REWORD_DAMPING=0.5
AI_SEMANTIC_FLOOR=0.10
AI_GRAY_BAND_LOW=0.03
AI_GRAY_BAND_HIGH=0.08
AI_MAX_ESCALATION_RATE=0.10
AI_NOTIFY_MODE=notify_then_enrich
AI_ENRICH_HOLD_SECONDS=30
ENRICH_MAX_ATTEMPTS=4
